# ─── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=autocare_db

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Frontend origin for CORS (no trailing slash)
FRONTEND_URL=http://localhost:3001
